# 이 파일을 복사해 `.env`로 저장한 뒤 값을 조정하세요. (`cp .env.example .env`)
# API 베이스는 http(s):// 로 시작하는 전체 URL이어야 합니다.

VITE_PATIENTS_API_BASE=https://vibe-pts-checkup-backend.onrender.com/api/patients

# 로컬 Express + Vite 프록시를 쓸 때만 아래를 참고하세요.
# VITE_DEV_PROXY_LOCAL=true
# VITE_PATIENTS_API_BASE=http://localhost:5000/api/patients
